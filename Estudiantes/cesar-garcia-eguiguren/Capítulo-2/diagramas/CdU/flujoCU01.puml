@startuml CU01_Autenticarse
!theme plain
skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #38BDF8
skinparam ActivityBorderColor #1E2840
skinparam ActivityBackgroundColor #141824
skinparam ActivityDiamondBackgroundColor #0D1018
skinparam ActivityDiamondBorderColor #38BDF8
skinparam NoteBackgroundColor #141824
skinparam NoteBorderColor #38BDF8

title CU-01 · Autenticarse en el Sistema

start
:El usuario accede a la pantalla de inicio de sesión;
:Introduce sus credenciales (usuario y contraseña);
:El sistema valida las credenciales;

if (¿Credenciales correctas?) then (NO)
  :Muestra mensaje de error;
  stop
else (SÍ)
  :El sistema verifica si el usuario
  tiene un empleado activo asociado;
  if (¿Empleado activo existe?) then (NO)
    :Deniega el acceso;
    stop
  else (SÍ)
    :El sistema determina el rol del usuario;
    if (¿Rol Director?) then (SÍ)
      :Se asigna acceso global sin restricciones;
    else (NO)
      if (¿Tiene permisos de Responsable?) then (SÍ)
        :Se asigna acceso filtrado según
        su ámbito organizativo;
      else (NO)
        :Se deniega el acceso al sistema;
        stop
      endif
    endif
    :Se crea la sesión del usuario;
    :El usuario accede al sistema principal;
    stop
  endif
endif

note right
  FA-01: Credenciales incorrectas → acceso denegado
  FA-02: Usuario sin empleado activo → acceso denegado
  FA-03: Sin permisos suficientes → acceso denegado
  FA-04: Sesión expirada → redirección al login
end note

@enduml
