@startuml CU02_ListarEmpleados
!theme plain
skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #38BDF8
skinparam ActivityBorderColor #1E2840
skinparam ActivityBackgroundColor #141824
skinparam ActivityDiamondBackgroundColor #0D1018
skinparam ActivityDiamondBorderColor #38BDF8
skinparam NoteBackgroundColor #141824
skinparam NoteBorderColor #38BDF8

title CU-02 · Listar Empleados

start
:El actor accede al listado de empleados;
:El sistema muestra la lista de empleados
disponibles según el rol del actor;

note right
  El Responsable solo ve los empleados
  de su ámbito organizativo.
  El Director ve todos los empleados.
end note

:El actor puede aplicar filtros:
· Búsqueda por nombre
· Filtro por departamento
· Mostrar solo activos;

:El sistema actualiza el listado
según los filtros aplicados;

if (¿Se encontraron empleados?) then (NO)
  :El sistema muestra un estado vacío;
  stop
else (SÍ)
  :El sistema muestra el listado paginado
  con la información de cada empleado;

  if (¿El actor selecciona un empleado?) then (SÍ)
    :Navega a CU-03 Resumen de Empleado;
  endif
  stop
endif

@enduml
