@startuml CU03_ResumenEmpleado
!theme plain
skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #38BDF8
skinparam ActivityBorderColor #1E2840
skinparam ActivityBackgroundColor #141824
skinparam ActivityDiamondBackgroundColor #0D1018
skinparam ActivityDiamondBorderColor #38BDF8
skinparam NoteBackgroundColor #141824
skinparam NoteBorderColor #38BDF8

title CU-03 · Consultar Resumen de Empleado

start
:El actor selecciona un empleado;
:El sistema verifica que el empleado
pertenece al ámbito del actor;

if (¿Empleado en el ámbito?) then (NO)
  :El sistema deniega el acceso;
  stop
else (SÍ)
  :El sistema muestra el perfil del empleado:
  · Datos personales y profesionales
  · Indicadores de carga de trabajo
  · WIP (tareas en paralelo)
  · Productividad reciente;

  :El actor visualiza las tareas del empleado
  organizadas por pestañas:
  · Pendientes
  · Completadas
  · Asignadas
  · Como responsable;

  :El actor puede aplicar filtros
  de rango de fechas sobre las tareas;

  if (¿El actor selecciona una tarea?) then (SÍ)
    :Navega a CU-09 Detalle de Tarea;
  endif
  stop
endif

note right
  FA-01: Empleado fuera del ámbito → acceso denegado
  FA-02: Empleado sin usuario vinculado
         → métricas a 0, tareas vacías
end note

@enduml
