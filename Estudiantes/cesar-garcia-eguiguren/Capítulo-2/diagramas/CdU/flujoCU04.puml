@startuml CU04_ListarDepartamentos
!theme plain
skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #38BDF8
skinparam ActivityBorderColor #1E2840
skinparam ActivityBackgroundColor #141824
skinparam ActivityDiamondBackgroundColor #0D1018
skinparam ActivityDiamondBorderColor #38BDF8
skinparam NoteBackgroundColor #141824
skinparam NoteBorderColor #38BDF8

title CU-04 · Listar Departamentos

start
:El actor accede al listado de departamentos;
:El sistema muestra los departamentos
disponibles según el rol del actor;

note right
  El Responsable solo ve los departamentos
  de su ámbito organizativo.
  El Director ve todos los departamentos.
end note

if (¿Existen departamentos disponibles?) then (NO)
  :El sistema muestra un estado vacío;
  stop
else (SÍ)
  :El sistema muestra la cuadrícula de
  departamentos con nombre y responsable;

  if (¿El actor selecciona un departamento?) then (SÍ)
    :Navega a CU-05 Resumen de Departamento;
  endif
  stop
endif

@enduml
