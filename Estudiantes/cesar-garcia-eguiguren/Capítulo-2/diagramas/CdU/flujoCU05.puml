@startuml CU05_ResumenDepartamento
!theme plain
skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #38BDF8
skinparam ActivityBorderColor #1E2840
skinparam ActivityBackgroundColor #141824
skinparam ActivityDiamondBackgroundColor #0D1018
skinparam ActivityDiamondBorderColor #38BDF8
skinparam NoteBackgroundColor #141824
skinparam NoteBorderColor #38BDF8
title CU-05 · Consultar Resumen de Departamento

start
:El actor selecciona un departamento;
:El sistema verifica que el departamento
pertenece al ámbito del actor;

if (¿Departamento en el ámbito?) then (NO)
  :El sistema deniega el acceso;
  stop
else (SÍ)
  :El sistema muestra el panel del departamento:
  · Nombre y responsable
  · Indicadores de distribución de carga
  · Alerta si hay empleados sobrecargados;

  :El actor selecciona una pestaña de visualización;

  if (Pestaña seleccionada) then (Carga de trabajo)
    :El sistema muestra la tabla de empleados
    con su porcentaje de carga y estado;
  else (Empleados)
    :El sistema muestra el listado de empleados
    del departamento con sus datos básicos;
  endif

  if (¿El actor selecciona un empleado?) then (SÍ)
    :Navega a CU-03 Resumen de Empleado;
  endif
  stop
endif

note right
  FA-01: Departamento fuera del ámbito → acceso denegado
  FA-02: Departamento sin empleados → pestañas vacías
end note

@enduml
