@startuml CU06_ListarProyectos
!theme plain
skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #38BDF8
skinparam ActivityBorderColor #1E2840
skinparam ActivityBackgroundColor #141824
skinparam ActivityDiamondBackgroundColor #0D1018
skinparam ActivityDiamondBorderColor #38BDF8
skinparam NoteBackgroundColor #141824
skinparam NoteBorderColor #38BDF8
title CU-06 · Listar Proyectos

start
:El actor accede al listado de proyectos;
:El sistema muestra los proyectos activos
disponibles según el rol del actor;

note right
  El Responsable solo ve los proyectos
  de su ámbito organizativo.
  El Director ve todos los proyectos.
end note

if (¿Existen proyectos disponibles?) then (NO)
  :El sistema muestra un estado vacío;
  stop
else (SÍ)
  :El sistema muestra la cuadrícula de proyectos
  con nombre, cliente y código;

  if (¿El actor selecciona un proyecto?) then (SÍ)
    :Navega a CU-07 Resumen de Proyecto;
  endif
  stop
endif

@enduml
