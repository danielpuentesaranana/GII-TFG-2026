@startuml CU07_ResumenProyecto
!theme plain
skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #38BDF8
skinparam ActivityBorderColor #1E2840
skinparam ActivityBackgroundColor #141824
skinparam ActivityDiamondBackgroundColor #0D1018
skinparam ActivityDiamondBorderColor #38BDF8
skinparam NoteBackgroundColor #141824
skinparam NoteBorderColor #38BDF8
title CU-07 · Consultar Resumen de Proyecto

start
:El actor selecciona un proyecto;
:El sistema verifica que el proyecto
pertenece al ámbito del actor;

if (¿Proyecto en el ámbito?) then (NO)
  :El sistema deniega el acceso;
  stop
else (SÍ)
  :El sistema muestra el panel del proyecto:
  · Nombre, cliente y código
  · Indicadores de eficiencia, riesgo
    y rentabilidad
  · Comparativa de horas estimadas vs. reales;

  :El actor selecciona una pestaña de visualización;

  if (Pestaña seleccionada) then (Tareas)
    :El sistema muestra las tareas del proyecto
    con opciones de filtro por estado y etapa;

    if (¿El actor selecciona una tarea?) then (SÍ)
      :Navega a CU-09 Detalle de Tarea;
    endif
  else (Equipo)
    :El sistema muestra los miembros del equipo
    con sus horas imputadas al proyecto;

    if (¿El actor selecciona un empleado?) then (SÍ)
      :Navega a CU-03 Resumen de Empleado;
    endif
  endif
  stop
endif

note right
  FA-01: Sin horas registradas
         → eficiencia y rentabilidad a 0
  FA-02: Proyecto fuera del ámbito → acceso denegado
end note

@enduml
