@startuml CU09_DetalleTarea
!theme plain
skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #38BDF8
skinparam ActivityBorderColor #1E2840
skinparam ActivityBackgroundColor #141824
skinparam ActivityDiamondBackgroundColor #0D1018
skinparam ActivityDiamondBorderColor #38BDF8
skinparam NoteBackgroundColor #141824
skinparam NoteBorderColor #38BDF8
title CU-09 · Consultar Detalle de Tarea

start
:El actor selecciona una tarea;
:El sistema verifica que la tarea
pertenece al ámbito del actor;

if (¿Tarea en el ámbito?) then (NO)
  :El sistema deniega el acceso;
  stop
else (SÍ)
  :El sistema muestra la ficha completa
  de la tarea:
  · Información general (proyecto, fechas)
  · Personas (responsable y asignados)
  · Horas (estimadas, invertidas, restantes)
  · Lista de subtareas si las hay;

  if (¿El actor navega al proyecto?) then (SÍ)
    :Navega a CU-07 Resumen de Proyecto;
  else if (¿El actor selecciona un empleado?) then (SÍ)
    :Navega a CU-03 Resumen de Empleado;
  else if (¿El actor selecciona una subtarea?) then (SÍ)
    :Navega a CU-09 Detalle de Tarea (recursivo);
  else if (¿El actor navega a la tarea padre?) then (SÍ)
    :Navega a CU-09 Detalle de Tarea (padre);
  endif
  stop
endif

note right
  FA-01: Tarea no encontrada → error 404
  FA-02: Tarea fuera del ámbito → acceso denegado
end note

@enduml
