@startuml CU10_ListarTareas
!theme plain
skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #38BDF8
skinparam ActivityBorderColor #1E2840
skinparam ActivityBackgroundColor #141824
skinparam ActivityDiamondBackgroundColor #0D1018
skinparam ActivityDiamondBorderColor #38BDF8
skinparam NoteFontColor #07090F

title CU-10 · Listar Tareas

start

:CU-01 (JWT válido);

:Determinar contexto de invocación;

if (Contexto) then (**Global /tareas**)
  :Actor configura filtros manualmente;
else if (Contexto) then (**Desde CU-09**)
  :project_id pre-rellenado
  GET /projects/{id}/tasks;
else (**Desde CU-05**)
  :employee_id [y status]
   pre-rellenados
  GET /employees/{id}/pending-tasks|completed-tasks|...;
endif

:GET /tasks/filter
 ?stage_id (prioridad sobre status)
 &status (pending|completed|overdue)
 &project_id & employee_id
 &date_from & date_to & date_assign
 &root_only & sort_by & sort_order
 &page & page_size=25;

note right
  Si stage_id está presente,
  el parámetro status es ignorado
  (lógica explícita en tasks.py)
end note

if (¿Responsable intenta proyecto fuera de scope?) then (SÍ)
  :HTTP 403;
  stop
endif

if (¿Responsable sin project_id?) then (SÍ)
  :Restringe automáticamente a project_ids del JWT;
endif

if (¿employee_id presente?) then (SÍ)
  :JOIN TaskAssignment → Employee (por Employee.id)
   para filtrar por empleado;
endif

if (¿Sin resultados?) then (SÍ)
  :EmptyState con mensaje;
  stop
endif

:Tabla paginada (25/página):
· Nombre tarea (link → CU-11)
· Etapa (Badge coloreado)
· Horas estimadas
· Deadline (rojo+⚠ si vencida y abierta)
· Fecha cierre
· Estado (Badge abierta/cerrada/cancelada);

:Ordenación global server-side
 por cualquier columna;

if (¿Click en tarea?) then (SÍ)
  :Navega a CU-11 /tareas/{id};
endif

:Paginación;

stop

@enduml