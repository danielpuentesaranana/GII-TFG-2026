@startuml CU22_Asistencia
!theme plain
skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #38BDF8
skinparam ActivityBorderColor #1E2840
skinparam ActivityBackgroundColor #141824
skinparam ActivityDiamondBackgroundColor #0D1018
skinparam ActivityDiamondBorderColor #38BDF8
skinparam NoteBackgroundColor #141824
skinparam NoteBorderColor #38BDF8
title CU-22 · Consultar Asistencia vs Imputaciones de Horas

start
:El actor accede a la página de asistencia;
:El sistema carga los datos del período
actual por defecto;

:El actor configura los filtros:
· Rango de fechas
· Departamento (opcional);

if (¿El actor es Director?) then (SÍ)
  :El actor puede elegir el modo de visualización:
  · Equipo global
  · Por responsable de área;

  if (Modo seleccionado) then (Por responsable)
    :El actor selecciona un responsable
    del listado disponible;
    if (¿Responsable seleccionado?) then (NO)
      :El sistema solicita seleccionar
      un responsable para continuar;
      stop
    endif
  endif
endif

:El sistema compara las horas fichadas
con las horas imputadas en partes de horas
para cada empleado del ámbito;

if (¿Existen datos en el período?) then (NO)
  :El sistema muestra los indicadores a cero
  y la tabla de empleados vacía;
  stop
else (SÍ)
  :El sistema muestra:
  · Indicadores globales del equipo
  · Gráfico comparativo por empleado
  · Tabla con cobertura individual
    y semáforo de estado;

  if (¿El actor selecciona un empleado?) then (SÍ)
    :El sistema muestra la serie diaria
    de horas fichadas e imputadas
    para ese empleado en el período;
  endif
  stop
endif

note right
  FA-01: Sin datos en el período → indicadores a 0
  FA-02: El Responsable solo accede al modo
         de equipo global, no por responsable
end note

@enduml
