@startuml CU23_Rentabilidad
!theme plain
skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #38BDF8
skinparam ActivityBorderColor #1E2840
skinparam ActivityBackgroundColor #141824
skinparam ActivityDiamondBackgroundColor #0D1018
skinparam ActivityDiamondBorderColor #38BDF8
skinparam NoteBackgroundColor #141824
skinparam NoteBorderColor #38BDF8
title CU-23 · Consultar Rentabilidad Financiera (Director exclusivo)

start
:El actor intenta acceder a la
página de rentabilidad;

if (¿El actor es Director?) then (NO)
  :El sistema muestra una pantalla
  de acceso restringido;
  stop
else (SÍ)
  :El actor configura los filtros:
  · Rango de fechas
  · Modo de análisis (Global / Por proyecto
    / Por responsable);

  :El sistema muestra el resumen financiero:
  · Ingresos totales
  · Gastos totales
  · Resultado neto
  · Rentabilidad porcentual
  · Gráfico comparativo por proyecto
  · Distribución de estados (ganancia/neutro/pérdida);

  :El actor selecciona una pestaña de desglose;

  if (Pestaña seleccionada) then (Por proyecto)
    :El sistema muestra la tabla de rentabilidad
    desglosada por proyecto;

    if (¿El actor solicita el detalle de un proyecto?) then (SÍ)
      :<<extend>> CU-24
      El sistema muestra las líneas analíticas
      individuales del proyecto;
    endif

  else (Por cliente)
    :El sistema muestra la tabla de rentabilidad
    agregada por cliente;

    if (¿El actor solicita el detalle de un cliente?) then (SÍ)
      :<<extend>> CU-25
      El sistema muestra las líneas analíticas
      del cliente agrupando todos sus proyectos;
    endif
  endif

  if (Modo == Por responsable AND responsable seleccionado) then (SÍ)
    :El sistema muestra el panel de rentabilidad
    del responsable seleccionado con sus proyectos;
  endif

  stop
endif

note right
  FA-01: Sin partes analíticos → indicadores a 0
  FA-02: Actor sin rol Director → pantalla restringida
end note

@enduml
