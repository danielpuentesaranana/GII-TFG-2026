@startuml CU25_LineasCliente
!theme plain
skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #38BDF8
skinparam ActivityBorderColor #1E2840
skinparam ActivityBackgroundColor #141824
skinparam ActivityDiamondBackgroundColor #0D1018
skinparam ActivityDiamondBorderColor #38BDF8
skinparam NoteBackgroundColor #141824
skinparam NoteBorderColor #38BDF8
title CU-25 · Consultar Líneas Analíticas de Cliente (Director exclusivo)

start
:El Director solicita el detalle
de un cliente desde CU-23;

:El sistema recupera todas las líneas
de partes analíticos de todos los
proyectos asociados al cliente
en el período indicado;

:El sistema clasifica las líneas en:
· Ingresos (importes positivos)
· Gastos (importes negativos);

if (¿Existen líneas en el período?) then (NO)
  :El sistema muestra las tablas vacías;
  stop
else (SÍ)
  :El sistema muestra dos tablas paralelas:
  · Tabla de Ingresos: fecha, descripción,
    importe, horas y proyecto de cada línea
  · Tabla de Gastos: mismos campos;
  stop
endif

note right
  Este caso de uso solo es accesible
  desde CU-23 (relación <<extend>>).
  Requiere rol Director.
  A diferencia de CU-24, agrega líneas
  de múltiples proyectos del mismo cliente.
end note

@enduml
