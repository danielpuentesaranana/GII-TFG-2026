@startuml CU26_BusquedaGlobal
!theme plain
skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #38BDF8
skinparam ActivityBorderColor #1E2840
skinparam ActivityBackgroundColor #141824
skinparam ActivityDiamondBackgroundColor #0D1018
skinparam ActivityDiamondBorderColor #38BDF8
skinparam NoteBackgroundColor #141824
skinparam NoteBorderColor #38BDF8
title CU-26 · Realizar Búsqueda Global

start
:El actor accede a la búsqueda global;
:El actor introduce el texto a buscar;

if (¿Texto con al menos 2 caracteres?) then (NO)
  :El sistema solicita introducir
  más caracteres para iniciar la búsqueda;
  stop
else (SÍ)
  :El sistema busca coincidencias en:
  · Tareas (por nombre o código)
  · Proyectos (por nombre o código)
  · Empleados (por nombre);

  note right
    El Responsable solo obtiene resultados
    dentro de su ámbito organizativo.
    El Director obtiene resultados globales.
  end note

  if (¿Se encontraron resultados?) then (NO)
    :El sistema muestra un estado vacío
    indicando que no hay coincidencias;
    stop
  else (SÍ)
    :El sistema muestra los resultados
    agrupados por tipo de entidad;

    :El actor puede filtrar los resultados
    por tipo (Todos / Tareas / Proyectos
    / Empleados);

    if (¿El actor selecciona un resultado?) then (SÍ)
      if (Tipo de resultado) then (Tarea)
        :Navega a CU-09 Detalle de Tarea;
      else if (Tipo de resultado) then (Proyecto)
        :Navega a CU-07 Resumen de Proyecto;
      else (Empleado)
        :Navega a CU-03 Resumen de Empleado;
      endif
    endif
    stop
  endif
endif

@enduml
