@startuml CU27_CerrarSesion
!theme plain
skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #38BDF8
skinparam ActivityBorderColor #1E2840
skinparam ActivityBackgroundColor #141824
skinparam ActivityDiamondBackgroundColor #0D1018
skinparam ActivityDiamondBorderColor #38BDF8
skinparam NoteBackgroundColor #141824
skinparam NoteBorderColor #38BDF8
title CU-27 · Cerrar Sesión

start
:El actor selecciona la opción
de cerrar sesión;

:El sistema invalida la sesión activa
y elimina las credenciales almacenadas
en el navegador;

:El sistema redirige al actor
a la pantalla de inicio de sesión;

stop

note right
  La sesión también puede cerrarse
  automáticamente si el token expira
  (flujo alternativo de CU-01 FA-04).
end note

@enduml
