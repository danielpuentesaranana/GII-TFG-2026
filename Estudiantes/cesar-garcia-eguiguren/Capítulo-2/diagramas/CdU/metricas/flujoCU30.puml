@startuml CU30_DistribucionPorCliente
!theme plain
skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #38BDF8
skinparam ActivityBorderColor #1E2840
skinparam ActivityBackgroundColor #141824
skinparam ActivityDiamondBackgroundColor #0D1018
skinparam ActivityDiamondBorderColor #38BDF8
skinparam NoteBackgroundColor #141824
skinparam NoteBorderColor #38BDF8
title CU-30 · Consultar Distribución por Cliente

start
:El Director selecciona la métrica
Distribución por Cliente;
:El Director configura el rango
de fechas de análisis;

:El sistema consulta las líneas analíticas
(account_analytic_line) del período
filtrando por project_id IS NOT NULL;

if (¿Existen líneas analíticas en el período?) then (NO)
  :El sistema muestra un panel vacío
  indicando que no hay datos para
  el período seleccionado;
  stop
else (SÍ)
  :El sistema agrupa las horas
  imputadas por cliente (res_partner)
  y calcula el porcentaje de cada
  cliente sobre el total;
  :El sistema muestra:
  · Gráfico de tarta por cliente
  · Tabla con nombre del cliente,
    horas totales y porcentaje;
  stop
endif

note right
  Acceso exclusivo del Director.
  Endpoint: GET /metrics/client-distribution
  Guard: require_director.
  No aplica filtrado por scope de ámbito.
end note

@enduml

