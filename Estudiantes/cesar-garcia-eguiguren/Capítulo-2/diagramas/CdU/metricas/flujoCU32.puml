@startuml CU32_RentabilidadPorHoras
!theme plain
skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #38BDF8
skinparam ActivityBorderColor #1E2840
skinparam ActivityBackgroundColor #141824
skinparam ActivityDiamondBackgroundColor #0D1018
skinparam ActivityDiamondBorderColor #38BDF8
skinparam NoteBackgroundColor #141824
skinparam NoteBorderColor #38BDF8
title CU-32 · Consultar Rentabilidad por Horas Estimadas/Reales

start
:El actor selecciona la métrica
Rentabilidad por Horas;
:El actor puede aplicar filtros opcionales:
· Proyecto concreto
· Rango de fechas;

if (¿El actor es Responsable y el proyecto\nno está en su ámbito?) then (SÍ)
  :El sistema deniega el acceso
  con error 403;
  stop
else (NO / Director)
  :El sistema compara las horas planificadas
  (planned_hours) con las horas reales
  registradas en partes de horas
  (account_analytic_line.unit_amount)
  para las tareas del ámbito;

  if (¿Existen tareas con ambos valores\ninformados?) then (NO)
    :El sistema muestra que no hay datos
    disponibles para los filtros aplicados;
    stop
  else (SÍ)
    :El sistema calcula:
    · Ratio = horas_estimadas / horas_reales × 100
    · Desviación total en horas
    · Impacto económico usando hourly_cost;
    :El sistema muestra:
    · Ratio global con semáforo
    · Desviación total en horas
    · Desglose por proyecto o tarea;
    stop
  endif
endif

note right
  Ratio > 100%: proyecto completado
  con menos horas de las previstas.
  Ratio < 100%: sobrecoste de horas.
  Acceso: Director (global) y
  Responsable (filtrado por scope).
end note

@enduml

