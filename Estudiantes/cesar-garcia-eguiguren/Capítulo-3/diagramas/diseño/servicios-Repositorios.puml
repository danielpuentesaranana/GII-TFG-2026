@startuml d06_dominio_repos
!theme plain
hide empty members
left to right direction

skinparam backgroundColor #07090f
skinparam classBackgroundColor #141824
skinparam classBorderColor #2a3850
skinparam packageBackgroundColor #0d1018
skinparam packageBorderColor #2a3850
skinparam defaultFontColor #c8d0dc
skinparam arrowColor #8896a8
skinparam shadowing false
skinparam nodesep 10
skinparam ranksep 70
skinparam NoteBackgroundColor #414c69

package "services/ (dominio)" {
  class AuthService
  class ScopeService
  class EmployeeService
  class DepartmentService
  class ProjectService
  class TaskService
  class ChartService
  class SearchService
  class DashboardService
}

package "repositories/ (base)" {
  class "auth.py"        as A  <<repo>>
  class "scope.py"       as S  <<repo>>
  class "employee.py"    as E  <<repo>>
  class "department.py"  as D  <<repo>>
  class "project.py"     as P  <<repo>>
  class "task.py"        as T  <<repo>>
  class "timesheet.py"   as TS <<repo>>
  class "chart.py"       as C  <<repo>>
  class "search.py"      as SE <<repo>>
  class "dashboard.py"   as DB <<repo>>
}

AuthService        -[#38bdf8]-> A

ScopeService       -[#a855f7]-> S

EmployeeService    -[#10b981]-> E

DepartmentService  -[#f59e0b]-> D
DepartmentService  -[#f59e0b]-> E

ProjectService     -[#ec4899]-> P
ProjectService     -[#ec4899]-> T
ProjectService     -[#ec4899]-> TS

TaskService        -[#f87171]-> T
TaskService        -[#f87171]-> E
TaskService        -[#f87171]-> TS

ChartService       -[#14b8a6]-> C
ChartService       -[#14b8a6]-> E

SearchService      -[#fbbf24]-> SE

DashboardService   -[#8b5cf6]-> DB
DashboardService   -[#8b5cf6]-> E


