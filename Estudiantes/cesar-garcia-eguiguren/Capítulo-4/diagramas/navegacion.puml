@startuml diagrama-navegacion-director
left to right direction
skinparam linetype polyline
skinparam backgroundColor white
skinparam dpi 400
state "<img:../imagenes/IniciarSesion.png{scale=0.6}>" as NoAuth
state "<img:../imagenes/Overview.png{scale=0.6}>" as Overview
state "<img:../imagenes/ListarEmpleados.png{scale=0.6}>" as ListEmp
state "<img:../imagenes/DetalleEmpleado.png{scale=0.6}>" as DetEmp
state "<img:../imagenes/ListarDptos.png{scale=0.6}>" as ListDept
state "<img:../imagenes/DetalleDpto.png{scale=0.6}>" as DetDept
state "<img:../imagenes/ListarProyectos.png{scale=0.6}>" as ListProy
state "<img:../imagenes/DetalleProyecto.png{scale=0.6}>" as DetProy
state "<img:../imagenes/ListarTareas.png{scale=0.6}>" as ListTarea
state "<img:../imagenes/DetalleTarea.png{scale=0.6}>" as DetTarea
state "<img:../imagenes/MostrarMetricas.png{scale=0.6}>" as Metricas
state "<img:../imagenes/GraficosAnaliticos.png{scale=0.6}>" as Graficos
state "<img:../imagenes/Asistencia.png{scale=0.6}>" as Asistencia
state "<img:../imagenes/Manager.png{scale=0.6}>" as Manager
state "<img:../imagenes/Busqueda.png{scale=0.6}>" as Busqueda
state "<img:../imagenes/Rentabilidad.png{scale=0.6}>" as Rentabilidad
state "<img:../imagenes/LineasAnaliticas.png{scale=0.6}>" as Lineas
state "<img:../imagenes/ListarSnapshot.png{scale=0.6}>" as Visor
state "<img:../imagenes/DetalleSnapshot.png{scale=0.6}>" as DetSnap
state "<img:../imagenes/PanelVisor.png{scale=0.6}>" as VisorInicial
' ── Estados individuales de métricas (P10) ────────────────────
state "<img:../imagenes/Productividad.png>" as MetProd
state "<img:../imagenes/Cumplimiento.png>" as MetCumpl
state "<img:../imagenes/WIP.png>" as MetWIP
state "<img:../imagenes/CargaTrabajo.png>" as MetWorkload
state "<img:../imagenes/IndiceRiesgo.png>" as MetRiesgo
state "<img:../imagenes/TasaRetrabajo.png>" as MetRetrabajo
state "<img:../imagenes/ExactitudEstimacion.png>" as MetEstimacion
state "<img:../imagenes/LeadTime.png>" as MetLeadTime
state "<img:../imagenes/DistribuciónClietes.png>" as MetDistCliente
state "<img:../imagenes/EficienciaProyecto.png>" as MetEficiencia
state "<img:../imagenes/Rentabilidad por horas.png>" as MetRentHoras

[*] --> NoAuth

' ── Autenticación ─────────────────────────────────────────────
NoAuth      --> Overview    : iniciarSesion()
Overview    --> NoAuth      : cerrarSesion()

' ── Navegación principal desde Overview ───────────────────────
Overview --> ListEmp        : listarEmpleados()
Overview --> ListDept       : listarDepartamentos()
Overview --> ListProy       : listarProyectos()
Overview --> ListTarea      : listarTareas()
Overview --> Metricas       : mostrarCatalogoMetricas()
Overview --> Graficos       : visualizarGraficosAnaliticos()
Overview --> Asistencia     : consultarAsistenciaVsImputaciones()
Overview --> Manager        : consultarCargaEquipo()
Overview --> Busqueda       : buscarGlobal()
Overview --> Rentabilidad   : analizarRentabilidadFinanciera()
VisorInicial   --> Visor          : listarSnapshots()
NoAuth   --> VisorInicial   : iniciarSesion()

ListDept     --> Overview : volver()
ListEmp      --> Overview : volver()
ListProy     --> Overview : volver()
ListTarea    --> Overview : volver()
Metricas     --> Overview : volver()
Asistencia   --> Overview : volver()
Rentabilidad --> Overview : volver()
Busqueda     --> Overview : volver()
Manager      --> Overview : volver()
Graficos     --> Overview : volver()

' ── P2 · Empleados ────────────────────────────────────────────
ListEmp  --> DetEmp         : visualizarResumenEmpleado()
DetEmp   --> ListTarea      : listarTareas()
DetEmp   --> DetEmp         : guardarSnapshot()
DetEmp   --> ListEmp        : volver()

' ── P3 · Departamentos ────────────────────────────────────────
ListDept --> DetDept         : visualizarResumenDepartamento()
DetDept  --> DetEmp          : visualizarResumenEmpleado()
DetDept  --> DetDept         : guardarSnapshot()
DetDept  --> ListDept        : volver()

' ── P4 · Proyectos ────────────────────────────────────────────
ListProy --> DetProy          : visualizarResumenProyecto()
DetProy  --> ListTarea        : listarTareas()
DetProy  --> DetEmp           : visualizarResumenEmpleado()
DetProy  --> DetProy          : guardarSnapshot()
DetProy  --> ListProy         : volver()

' ── P5 · Tareas ───────────────────────────────────────────────
ListTarea --> DetTarea        : consultarDetalleTarea()
DetTarea  --> DetProy         : visualizarResumenProyecto()
DetTarea  --> DetEmp          : visualizarResumenEmpleado()
DetTarea  --> DetTarea        : consultarDetalleTarea()
DetTarea  --> DetTarea        : guardarSnapshot()
DetTarea  --> ListTarea       : volver()

' ── P6 · Catálogo de métricas → P10 Métricas individuales ─────
Metricas --> MetProd            : consultarProductividad()
Metricas --> MetCumpl           : consultarCumplimiento()
Metricas --> MetWIP             : consultarWIP()
Metricas --> MetWorkload        : consultarCargaTrabajo()
Metricas --> MetRiesgo          : consultarRiesgoProyecto()
Metricas --> MetRetrabajo       : consultarRetrabajo()
Metricas --> MetEstimacion      : consultarExactitudEstimacion()
Metricas --> MetLeadTime        : consultarLeadTime()
Metricas --> MetDistCliente     : consultarDistribucionCliente()
Metricas --> MetEficiencia      : consultarEficienciaProyecto()
Metricas --> MetRentHoras       : consultarRentabilidadHoras()

' ── P10 · Métricas individuales (patrón común) ────────────────
MetProd          --> MetProd          : guardarSnapshot()
MetProd          --> Metricas         : volver()
MetCumpl         --> MetCumpl         : guardarSnapshot()
MetCumpl         --> Metricas         : volver()
MetWIP           --> MetWIP           : guardarSnapshot()
MetWIP           --> Metricas         : volver()
MetWorkload      --> MetWorkload      : guardarSnapshot()
MetWorkload      --> Metricas         : volver()
MetRiesgo        --> MetRiesgo        : guardarSnapshot()
MetRiesgo        --> Metricas         : volver()
MetRetrabajo     --> MetRetrabajo     : guardarSnapshot()
MetRetrabajo     --> Metricas         : volver()
MetEstimacion    --> MetEstimacion    : guardarSnapshot()
MetEstimacion    --> Metricas         : volver()
MetLeadTime      --> MetLeadTime      : guardarSnapshot()
MetLeadTime      --> Metricas         : volver()
MetDistCliente   --> MetDistCliente   : guardarSnapshot()
MetDistCliente   --> Metricas         : volver()
MetEficiencia    --> MetEficiencia    : guardarSnapshot()
MetEficiencia    --> Metricas         : volver()
MetRentHoras     --> MetRentHoras     : guardarSnapshot()
MetRentHoras     --> Metricas         : volver()

' ── P6 · Otros análisis ───────────────────────────────────────
Graficos   --> Graficos       : guardarSnapshot()
Asistencia --> Asistencia     : guardarSnapshot()
Manager    --> DetEmp         : visualizarResumenEmpleado()

' ── P7 · Rentabilidad ★ Director exclusivo ───────────────────
Rentabilidad --> Lineas       : consultarLineasAnaliticas()
Rentabilidad --> Rentabilidad : guardarSnapshot()
Lineas       --> Rentabilidad : volver()

' ── P8 · Utilidades ───────────────────────────────────────────
Busqueda --> DetEmp           : visualizarResumenEmpleado()
Busqueda --> DetProy          : visualizarResumenProyecto()
Busqueda --> DetTarea         : consultarDetalleTarea()

' ── P9 · Snapshots ────────────────────────────────────────────
Visor    --> DetSnap          : consultarDetalleSnapshot()
VisorInicial    --> NoAuth           : cerrarSesion()
Visor --> Visor : eliminarSnapshot()
DetSnap  --> Visor            : eliminarSnapshot()
DetSnap  --> Visor            : volver()
Visor --> VisorInicial     : volver()

@enduml