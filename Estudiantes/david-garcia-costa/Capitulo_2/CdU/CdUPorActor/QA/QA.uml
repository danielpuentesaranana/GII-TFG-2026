@startuml
left to right direction
title Casos de uso - Ingeniero de QA

actor "Ingeniero de QA" as QA

rectangle "Sistema" {
  usecase "Iniciar\nsesion" as CU01
  usecase "Cerrar\nsesion" as CU02

  usecase "Introducir\ndocumentacion funcional" as CU03
  usecase "Asociar documentacion\na proyecto" as CU04
  usecase "Consultar referencias de documentacion\nde un proyecto" as CU05
  usecase "Listar\ndocumentacion" as CU06
  usecase "Consultar\ndocumentacion" as CU07
  usecase "Actualizar\ndocumentacion" as CU08
  usecase "Eliminar\ndocumentacion" as CU09

  usecase "Listar\ncasos de uso" as CU10
  usecase "Consultar\ncaso de uso" as CU11
  usecase "Crear\ncaso de uso" as CU12
  usecase "Actualizar\ncaso de uso" as CU13
  usecase "Eliminar\ncaso de uso" as CU14

  usecase "Listar requisitos\nfuncionales" as CU15
  usecase "Consultar requisito\nfuncional" as CU16
  usecase "Crear requisito\nfuncional" as CU17
  usecase "Actualizar requisito\nfuncional" as CU18
  usecase "Eliminar requisito\nfuncional" as CU19

  usecase "Listar escenarios\nGherkin" as CU20
  usecase "Crear escenario\nGherkin" as CU21
  usecase "Consultar escenario\nGherkin" as CU22
  usecase "Actualizar escenario\nGherkin" as CU23
  usecase "Eliminar escenario\nGherkin" as CU24

  usecase "Crear borrador de\ncaso de prueba" as CU25
  usecase "Listar\nborradores" as CU26
  usecase "Consultar\nborrador" as CU27
  usecase "Anadir feedback\na borrador" as CU28
  usecase "Rechazar\nborrador" as CU29
  usecase "Aceptar y publicar caso de prueba\na partir de borrador" as CU30

  usecase "Buscar casos de prueba\nen Kiwi TCMS" as CU31
  usecase "Ver caso de prueba\nen Kiwi TCMS" as CU32
  usecase "Seleccionar\nsesiones" as CU33
  usecase "Crear nueva\nsesion" as CU34
  usecase "Eliminar\nsesion" as CU35
  usecase "Guardar\nresultados" as CU36
  usecase "Registrar\ncuenta" as CU38
  usecase "Crear traspaso\nal flujo automatico" as CU39
}

