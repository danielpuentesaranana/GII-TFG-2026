@startuml
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0

title CU-21 - Crear escenario Gherkin

package "Vista" {
  class GherkinScenariosView
}

package "Controlador" {
  class GherkinController
}

package "Modelo" {
  class GherkinScenario
  class UseCase
  class FunctionalRequirement
  class Session
}

GherkinScenariosView --> GherkinController : POST /api/scenarios
GherkinController --> GherkinScenario : crear escenario
GherkinController --> UseCase : ucId
GherkinController --> FunctionalRequirement : rfIds
GherkinController --> Session : sessionId

@enduml
