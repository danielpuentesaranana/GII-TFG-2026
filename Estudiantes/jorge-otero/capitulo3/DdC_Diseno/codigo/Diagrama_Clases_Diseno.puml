@startuml Diagrama_Clases_Diseno

top to bottom direction
skinparam packageStyle rectangle
hide empty members

package "Controladores / Flujos" {

  class RecibirSolicitudFlow {
    + procesarCorreo(correo: CorreoRecibido): void
    + clasificarAsunto(asunto: String): String
    + analizarIntencion(cuerpo: String): String
    + extraerNumero(cuerpo: String): String
    + consultarDatosSolicitud(numero: String): Solicitud
    + generarRespuesta(solicitud: Solicitud, intencion: String): String
    + registrarCorreo(correo: CorreoRecibido): void
    + registrarSolicitud(solicitud: Solicitud): void
  }

  class RecibirFormularioFlow {
    + procesarFormulario(formulario: Formulario): void
    + validarDocumentacion(formulario: Formulario): Boolean
    + registrarFormulario(formulario: Formulario): void
    + actualizarEstadoSolicitud(solicitud: Solicitud): void
    + enviarInstruccionesDocumentacion(formulario: Formulario): void
  }
}

package "Entidades del dominio" {

  class CorreoRecibido {
    + idCorreo: int
    + asunto: String
    + remitente: String
    + cuerpo: String
    + fechaRecepcion: DateTime
    + intencion: String
  }

  class Solicitud {
    + numero: String
    + provincia: String
    + tecnico: String
    + eecc: String
    + totalConsultas: int
    + estado: String
  }

  class Formulario {
    + idFormulario: String
    + idSolicitud: String
    + fechaEnvio: DateTime
    + fechaResolucion: DateTime
    + respuestas: String
    + documentacionMarcada: Boolean
    + estado: Boolean
  }
}

package "Acceso a datos" {

  class DatasetConsultaPowerBI <<dataset>> {
    + consultarObra(numero: String): Solicitud
    + consultarTecnico(numero: String): String
    + consultarEECC(numero: String): String
  }

  class DatasetRegistroPowerBI <<dataset>> {
    + guardarCorreo(correo: CorreoRecibido): void
    + guardarSolicitud(solicitud: Solicitud): void
    + guardarFormulario(formulario: Formulario): void
    + actualizarSolicitud(solicitud: Solicitud): void
  }
}

package "Interfaces externas" {

  class ExchangeOnline <<external>> {
    + recibirCorreo(): CorreoRecibido
    + enviarCorreo(destinatario: String, asunto: String, cuerpo: String): void
    + moverCorreo(carpeta: String): void
  }

  class MicrosoftForms <<external>> {
    + recibirFormulario(): Formulario
    + obtenerRespuestas(idFormulario: String): Formulario
  }

  class InformePowerBI <<vista>> {
    + mostrarSolicitudes(): List<Solicitud>
    + mostrarFormularios(): List<Formulario>
    + mostrarHistoricoCorreos(): List<CorreoRecibido>
    + filtrarDatos(): void
  }
}

RecibirSolicitudFlow --> ExchangeOnline
RecibirSolicitudFlow --> DatasetConsultaPowerBI
RecibirSolicitudFlow --> DatasetRegistroPowerBI
RecibirSolicitudFlow --> CorreoRecibido
RecibirSolicitudFlow --> Solicitud

RecibirFormularioFlow --> MicrosoftForms
RecibirFormularioFlow --> ExchangeOnline
RecibirFormularioFlow --> DatasetRegistroPowerBI
RecibirFormularioFlow --> Formulario
RecibirFormularioFlow --> Solicitud

DatasetRegistroPowerBI --> CorreoRecibido
DatasetRegistroPowerBI --> Solicitud
DatasetRegistroPowerBI --> Formulario

DatasetConsultaPowerBI --> Solicitud

Solicitud "1" -- "0..*" Formulario

InformePowerBI --> DatasetRegistroPowerBI

@enduml