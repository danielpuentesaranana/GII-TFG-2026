@startuml EnviarSolicitud
title Diagrama de Secuencia - Enviar Solicitud

actor Cliente
participant "Outlook" as Outlook
participant "EnviarSolicitudFlow" as Flow
participant "Solicitud" as Solicitud
database "Power BI" as PowerBI

Cliente -> Outlook : enviarCorreoSolicitud(datos)
Outlook -> Flow : detectarCorreoEntrante(datos)
Flow -> Flow : procesarSolicitud(datos)
Flow -> Solicitud : crearSolicitud(datos)
Solicitud --> Flow : solicitudCreada
Flow -> PowerBI : registrarSolicitud(solicitud)
PowerBI --> Flow : registroConfirmado

@enduml