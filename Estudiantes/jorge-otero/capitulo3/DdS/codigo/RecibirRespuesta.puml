@startuml RecibirRespuesta
title Diagrama de Secuencia - Recibir Respuesta

participant "RecibirRespuestaFlow" as Flow
participant "Solicitud" as Solicitud
participant "Respuesta" as Respuesta
participant "Outlook" as Outlook
actor Cliente

Flow -> Flow : procesarSolicitud(solicitud)
Flow -> Flow : identificarIntencion(solicitud)
Flow -> Solicitud : obtenerDatosSolicitud()
Solicitud --> Flow : datosSolicitud
Flow -> Respuesta : generarRespuesta(datosSolicitud, intencion)
Respuesta --> Flow : respuestaGenerada
Flow -> Outlook : enviarRespuesta(respuesta)
Outlook --> Cliente : recibirRespuesta(respuesta)

@enduml